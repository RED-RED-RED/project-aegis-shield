# ============================================================
# AEGIS Server — environment variable template
# Copy to .env and set real values before running:
#   cp .env.example .env
# ============================================================

# ---- Database -----------------------------------------------
DB_NAME=ridmesh
DB_USER=ridmesh
DB_PASSWORD=changeme

# ---- MQTT ---------------------------------------------------
MQTT_USER=rid
MQTT_PASSWORD=changeme

# ---- API authentication (optional) -------------------------
# Leave empty to disable auth on all API endpoints.
# Set to a random secret string to require X-Api-Key header.
# AEGIS_API_KEY=

# ---- Algo 8128 IP Visual Alerter (optional) -----------------
# Set ALGO_8128_ENABLED=true to activate strobe alerts.
# The 8128 REST API must be enabled via its web interface first
# (Admin → Services → REST API → Enable).

# Enable the integration (default: false — zero overhead when disabled)
ALGO_8128_ENABLED=false

# LAN address of the Algo 8128 unit
ALGO_8128_URL=http://192.168.1.50

# Bearer token configured on the 8128 web interface (Admin → Security → API Key)
ALGO_8128_API_KEY=

# Minimum seconds between repeat triggers for the same drone at the same threat level.
# Escalations (LOW→MEDIUM, MEDIUM→HIGH) always bypass this window.
ALGO_8128_COOLDOWN_SECONDS=30
